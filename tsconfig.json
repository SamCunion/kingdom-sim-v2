{
    "compilerOptions": {
        "outDir": "./public/",
        "rootDir": ".",
        "noImplicitAny": true,
        "module": "node20",
        "target": "es2025",
        "jsx": "react",
        "allowJs": true,
        "moduleResolution": "nodenext",
        "resolveJsonModule": true,
        "esModuleInterop": true
    },
    "include": [
        "./src/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}